// Modul ORM untuk Tenun — CRUD aman (berparameter) untuk MySQL & PostgreSQL.
// Nilai tidak pernah digabung mentah ke SQL: Postgres memakai prepared ($1..),
// MySQL memakai escape kuat. Pengguna memanggil fungsi CRUD, bukan menulis SQL.

impor "mysql";
impor "postgres";

impor "./koneksi.tenun";
impor "./kueri.tenun";
impor "./crud.tenun";
